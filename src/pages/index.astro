---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import Card from '../components/Card.astro';
import { siteConfig } from '../config';

const title = `Home - ${siteConfig.title}`;
const description = siteConfig.description;
---

<Layout title={title} description={description}>
  <Hero />
  
  <section id="learn-more" class="py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-transparent via-blue-50 to-transparent">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6">How We Support You</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
          Every journey toward healing is unique. We're here to walk alongside you with compassion, without judgment.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {siteConfig.services.map((service) => (
          <Card 
            title={service.title}
            description={service.description}
            icon={service.icon}
            href="/services"
          />
        ))}
      </div>
    </div>
  </section>

  <CTA 
    title="You Don't Have to Walk This Alone"
    description="Reach out to us. We're here to listen, support, and help you find your way forward."
  />
</Layout>
