---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import CTA from '../components/CTA.astro';
import { siteConfig } from '../config';
---

<Layout title={`Services - ${siteConfig.title}`} description="Explore the compassionate support services we offer">
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-transparent via-blue-50 to-transparent">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">How We Support You</h1>
      <p class="text-lg text-gray-700 mb-12">
        Every person's healing journey is unique. We offer compassionate support tailored to meet you where you are.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {siteConfig.services.map((service) => (
          <div class="bg-white rounded-lg shadow-md p-8 hover:shadow-lg transition">
            <div class="text-5xl mb-4">{service.icon}</div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3">{service.title}</h3>
            <p class="text-gray-700">{service.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 p-8 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">What To Expect</h2>
        <ol class="space-y-4">
          <li class="flex items-start">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-blue-600 text-white font-bold mr-4 flex-shrink-0">1</span>
            <div>
              <h3 class="font-bold text-gray-900">Initial Connection</h3>
              <p class="text-gray-700">Reach out to us. We'll listen to understand your situation, no pressure, no judgment.</p>
            </div>
          </li>
          <li class="flex items-start">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-indigo-600 text-white font-bold mr-4 flex-shrink-0">2</span>
            <div>
              <h3 class="font-bold text-gray-900">Building Trust</h3>
              <p class="text-gray-700">Through consistent, compassionate support, we build a relationship of genuine trust.</p>
            </div>
          </li>
          <li class="flex items-start">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-teal-600 text-white font-bold mr-4 flex-shrink-0">3</span>
            <div>
              <h3 class="font-bold text-gray-900">Shared Growth</h3>
              <p class="text-gray-700">Together, we explore what healing means for you and support your unique journey.</p>
            </div>
          </li>
          <li class="flex items-start">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-cyan-600 text-white font-bold mr-4 flex-shrink-0">4</span>
            <div>
              <h3 class="font-bold text-gray-900">Ongoing Support</h3>
              <p class="text-gray-700">Your journey continues. We're here for the ups and downs, celebrating progress together.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <CTA 
    title="Take the First Step"
    description="Reach out today to begin your healing journey with compassionate support."
  />
</Layout>
