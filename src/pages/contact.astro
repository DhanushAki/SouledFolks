---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { siteConfig } from '../config';
---

<Layout title={`Contact - ${siteConfig.title}`} description="Reach out to our compassionate team - we're here to listen and support you">
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-transparent via-blue-50 to-transparent">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Reach Out, We're Listening</h1>
      <p class="text-lg text-gray-700 mb-8">
        Whether you have questions, want to share your story, or need support, we're here for you. 
        There's no judgment, only genuine care.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="p-6 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-lg border border-blue-200">
          <svg class="w-8 h-8 text-blue-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          <h3 class="font-bold text-gray-900 mb-2">Email</h3>
          <a href={`mailto:${siteConfig.email}`} class="text-blue-600 hover:text-indigo-600 transition-colors font-semibold">
            {siteConfig.email}
          </a>
        </div>

        <div class="p-6 bg-gradient-to-br from-indigo-50 to-purple-50 rounded-lg border border-indigo-200">
          <svg class="w-8 h-8 text-indigo-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 00.948.684l1.498 4.493a1 1 0 00.502.756l2.73 1.365a1 1 0 001.27-.667l2.14-7.498a1 1 0 00-.948-1.684h-5.5a1 1 0 00-1 1v2.5M9 12l4 0m4 0l-4 0m0 0l.003.003"></path>
          </svg>
          <h3 class="font-bold text-gray-900 mb-2">Phone</h3>
          <a href={`tel:${siteConfig.phone}`} class="text-indigo-600 hover:text-purple-600 transition-colors font-semibold">
            {siteConfig.phone}
          </a>
        </div>

        <div class="p-6 bg-gradient-to-br from-teal-50 to-cyan-50 rounded-lg border border-teal-200">
          <svg class="w-8 h-8 text-teal-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h3 class="font-bold text-gray-900 mb-2">Response Time</h3>
          <p class="text-gray-700 font-semibold">We care about your message and respond within 24 hours</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Share Your Story</h2>
          <p class="text-gray-700 mb-6">
            Tell us what brought you here. Whether it's a question, a concern, or just wanting to connect—we're genuinely interested in listening.
          </p>
          <form id="contact-form" class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">
                Full Name <span class="text-red-500">*</span>
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                aria-required="true"
              />
              <span class="error-message text-red-500 text-sm mt-1 hidden"></span>
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
                Email Address <span class="text-red-500">*</span>
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                aria-required="true"
              />
              <span class="error-message text-red-500 text-sm mt-1 hidden"></span>
            </div>

            <div>
              <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">
                Phone Number
              </label>
              <input 
                type="tel" 
                id="phone" 
                name="phone"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-semibold text-gray-700 mb-2">
                Subject <span class="text-red-500">*</span>
              </label>
              <input 
                type="text" 
                id="subject" 
                name="subject" 
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                aria-required="true"
              />
              <span class="error-message text-red-500 text-sm mt-1 hidden"></span>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">
                Message <span class="text-red-500">*</span>
              </label>
              <textarea 
                id="message" 
                name="message" 
                required
                rows="6"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors resize-none"
                aria-required="true"
              ></textarea>
              <span class="error-message text-red-500 text-sm mt-1 hidden"></span>
            </div>

            <div class="p-4 bg-blue-50 border-l-4 border-blue-400 rounded">
              <p class="text-sm text-blue-800">
                <strong>💙 Important:</strong> Your safety and privacy matter deeply to us. Please don't share medical diagnoses or sensitive health details here. If you're in crisis, please reach out to emergency services or our 24/7 crisis line.
              </p>
            </div>

            <button 
              type="submit"
              class="w-full bg-blue-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-blue-700 transition-colors"
            >
              Send Message
            </button>
          </form>
          <p class="text-sm text-gray-600 mt-4">All fields marked with <span class="text-red-500">*</span> are required.</p>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Additional Support</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-gray-900 mb-2">📞 Talk to Someone</h3>
              <p class="text-gray-700 mb-4">
                Sometimes a direct conversation is what you need. We're here to listen with an open heart.
              </p>
              <a 
                href={`tel:${siteConfig.phone}`}
                class="inline-flex items-center text-blue-600 font-semibold hover:text-indigo-600"
              >
                Call Us Now
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <div>
              <h3 class="font-bold text-gray-900 mb-2">🆘 In Crisis?</h3>
              <p class="text-gray-700 mb-4">
                If you're experiencing a crisis or having thoughts of self-harm, immediate help is available 24/7.
              </p>
              <a 
                href="tel:988"
                class="inline-flex items-center text-red-600 font-semibold hover:text-red-700"
              >
                Call 988 (Suicide & Crisis Lifeline)
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <div class="p-6 bg-gradient-to-br from-indigo-50 to-blue-50 rounded-lg border border-indigo-200">
              <h3 class="font-bold text-gray-900 mb-2">💙 Community</h3>
              <p class="text-gray-700 mb-4">You're not alone. Connect with our community for support and shared experiences.</p>
              <div class="flex space-x-4">
                {siteConfig.social.twitter && (
                  <a href={siteConfig.social.twitter} class="text-gray-600 hover:text-blue-600 transition-colors" aria-label="Twitter">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7a10.6 10.6 0 01-9-5.5z"></path></svg>
                  </a>
                )}
                {siteConfig.social.facebook && (
                  <a href={siteConfig.social.facebook} class="text-gray-600 hover:text-blue-600 transition-colors" aria-label="Facebook">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a6 6 0 00-6 6v3H7v4h2v8h4v-8h3l1-4h-4V8a2 2 0 012-2h3z"></path></svg>
                  </a>
                )}
                {siteConfig.social.linkedin && (
                  <a href={siteConfig.social.linkedin} class="text-gray-600 hover:text-blue-600 transition-colors" aria-label="LinkedIn">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path><circle cx="4" cy="4" r="2"></circle></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA 
    title="Your Voice Matters"
    description="Reach out today. We're listening with open hearts and genuine care."
  />
</Layout>

<script>
  const form = document.getElementById('contact-form');
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Reset error messages
      const errorMessages = form.querySelectorAll('.error-message');
      errorMessages.forEach(msg => msg.classList.add('hidden'));

      const formData = new FormData(form);
      const name = formData.get('name')?.trim();
      const email = formData.get('email')?.trim();
      const subject = formData.get('subject')?.trim();
      const message = formData.get('message')?.trim();
      
      let isValid = true;

      // Validation
      if (!name) {
        form.querySelector('[name="name"]').nextElementSibling.textContent = 'Name is required';
        form.querySelector('[name="name"]').nextElementSibling.classList.remove('hidden');
        isValid = false;
      }

      if (!email) {
        form.querySelector('[name="email"]').nextElementSibling.textContent = 'Email is required';
        form.querySelector('[name="email"]').nextElementSibling.classList.remove('hidden');
        isValid = false;
      } else if (!email.includes('@')) {
        form.querySelector('[name="email"]').nextElementSibling.textContent = 'Please enter a valid email';
        form.querySelector('[name="email"]').nextElementSibling.classList.remove('hidden');
        isValid = false;
      }

      if (!subject) {
        form.querySelector('[name="subject"]').nextElementSibling.textContent = 'Subject is required';
        form.querySelector('[name="subject"]').nextElementSibling.classList.remove('hidden');
        isValid = false;
      }

      if (!message) {
        form.querySelector('[name="message"]').nextElementSibling.textContent = 'Message is required';
        form.querySelector('[name="message"]').nextElementSibling.classList.remove('hidden');
        isValid = false;
      }

      if (isValid) {
        // Fallback to mailto
        const subject_encoded = encodeURIComponent(subject);
        const message_encoded = encodeURIComponent(`From: ${name} (${email})\n\n${message}`);
        window.location.href = `mailto:${siteConfig.email}?subject=${subject_encoded}&body=${message_encoded}`;
        form.reset();
      }
    });
  }
</script>
