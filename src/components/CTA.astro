---
interface Props {
  title?: string;
  description?: string;
  cta?: string;
  ctaLink?: string;
  dark?: boolean;
}

const {
  title = "Ready to get started?",
  description = "Take the first step towards better mental health today.",
  cta = "Contact Us",
  ctaLink = "/contact",
  dark = false
} = Astro.props;
---

<section class={`py-16 px-4 sm:px-6 lg:px-8 ${
  dark 
    ? 'bg-gray-900 text-white' 
    : 'bg-gradient-to-r from-blue-600 to-indigo-600 text-white'
}`}>
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">{title}</h2>
    <p class="text-lg opacity-90 mb-8">{description}</p>
    <a 
      href={ctaLink}
      class={`inline-flex items-center justify-center px-8 py-3 font-semibold rounded-lg transition-all duration-200 ${
        dark
          ? 'bg-blue-600 hover:bg-blue-700'
          : 'bg-white text-blue-600 hover:bg-gray-100'
      }`}
      aria-label={cta}
    >
      {cta}
      <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
      </svg>
    </a>
  </div>
</section>
